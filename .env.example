# ================================================================
# GoTime Transportation — Environment Variables Template
# Copy this file to the appropriate location and fill in values.
# NEVER commit .env files with real secrets to version control.
# ================================================================

# ---------------------------------------------------------------
# frontend/.env  (Vite — all vars must be prefixed VITE_)
# ---------------------------------------------------------------

# Your Supabase project URL (find in Supabase → Settings → API)
VITE_SUPABASE_URL=https://qmublulpbgcaujtbepru.supabase.co

# Supabase anon/public key (safe to expose in browser)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFtdWJsdWxwYmdjYXVqdGJlcHJ1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYxNjM4MTEsImV4cCI6MjA5MTczOTgxMX0.EIBXGlIOrpcG73uoy1J11rWgkvWOYZcpljeAcILj0zM

# FastAPI backend URL (local dev: http://localhost:8000/api)
VITE_API_URL=http://localhost:8000/api

# Optional: force a mock role when using dev bypass login
# Values: intake_staff | senior_dispatcher | admin  (default: admin)
VITE_DEV_MOCK_ROLE=admin


# ---------------------------------------------------------------
# backend/.env  (Python / FastAPI)
# ---------------------------------------------------------------

# Supabase project URL (same as above)
SUPABASE_URL=https://qmublulpbgcaujtbepru.supabase.co

# Supabase anon key (used for public reads if needed)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFtdWJsdWxwYmdjYXVqdGJlcHJ1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYxNjM4MTEsImV4cCI6MjA5MTczOTgxMX0.EIBXGlIOrpcG73uoy1J11rWgkvWOYZcpljeAcILj0zM

# Supabase service role key — KEEP SECRET, grants full DB access
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Random secret for any internal signing (generate: openssl rand -hex 32)
API_SECRET_KEY=changeme-generate-a-real-secret

# development | staging | production
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# n8n webhook base URL (set after n8n instance is running)
N8N_WEBHOOK_BASE_URL=https://primary-production-6722.up.railway.app/webhook/39ff5f08-e2b4-439f-8bc0-95f3bdf7d41f

# Twilio credentials (set after BAA is signed)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid credentials (set after BAA is signed)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
